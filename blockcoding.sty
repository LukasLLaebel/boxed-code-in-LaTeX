\definecolor{css-valuecolor}{RGB}{255,130,80}   % Orange for values

% Define CSS language
\lstdefinelanguage{CSS}{
  morekeywords={color, background, margin, padding, border, font, width, height, display, position, top, left, right, bottom, z-index, opacity, transform, transition, animation, flex, grid, text-align, font-size, line-height, box-sizing, overflow, cursor, visibility, white-space, word-wrap, text-decoration, font-weight, font-family, background-color, border-radius, box-shadow, text-shadow, justify-content, align-items, gap, flex-direction, font-style, letter-spacing, text-transform, background-image, border-color, border-width, border-style, min-width, max-width, min-height, max-height, content},
  keywordstyle=\color{css-propcolor}\bfseries,
  sensitive=false,
  morecomment=[s]{/*}{*/},
  commentstyle=\color{css-commentcolor}\itshape,
  stringstyle=\color{css-stringcolor},
  morestring=[b]",
  morestring=[b]',
  alsoletter={-},
    literate={)}{}{1}
           {:}{{\textcolor{css-codefg}{:}}}1
           {;}{{\textcolor{css-codefg}{;}}}1
}

% CSS style with selector highlighting before braces
\lstdefinestyle{css}{
  backgroundcolor=\color{css-codebg},
  basicstyle=\ttfamily\small\color{css-codefg},
  keywordstyle=\color{css-propcolor}\bfseries,
  commentstyle=\color{css-commentcolor}\itshape,
  numberstyle=\tiny\color{gray},
  numbers=left,
  numbersep=10pt,
  columns=fullflexible,
  keepspaces=true,
  showstringspaces=false,
  breaklines=true,
  frame=single,
  language=CSS,
  moredelim=[is][\color{css-selectorcolor}]{\(}{\ \{},
  moredelim=[is][\color{css-valuecolor}]{:}{;}
}



