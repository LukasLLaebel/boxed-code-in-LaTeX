% Default colors
\definecolor{codebg}{RGB}{30,30,30} 			% Black background
\definecolor{codefg}{RGB}{240,240,240}
\definecolor{stringcolor}{RGB}{80,200,120}
\definecolor{commentcolor}{RGB}{130,130,130}
\definecolor{keywordcolor}{RGB}{255,130,80}
\definecolor{gray}{rgb}{0.5,0.5,0.5}
\definecolor{operatorcolor}{RGB}{173, 216, 230}
\definecolor{specialfuncColor}{RGB}{255, 105, 180}
\definecolor{functionscolor}{RGB}{50, 170, 230}
\definecolor{commonfuncs}{RGB}{255, 255, 0}

% Define JavaScript language
\lstdefinelanguage{JavaScript}{
  keywords={typeof, new, true, false, catch, function, return, null, switch, var, let, const, if, in, while, do, else, case, break, for, get, post, put, delete},
  keywordstyle=\color{keywordcolor}\bfseries,
  ndkeywords={class, export, boolean, throw, implements, import, this,async,await},
  ndkeywordstyle=\color{specialfuncColor}\bfseries,
  morekeywords=[2]{router},
  keywordstyle=[2]\color{functionscolor}\bfseries,
  morekeywords=[3]{%
    fetch, setTimeout, clearTimeout, setInterval, clearInterval, parseInt, parseFloat, isNaN, isFinite,
    encodeURIComponent, decodeURIComponent, structuredClone, push, pop, shift, unshift, splice, slice,
    forEach, map, filter, reduce, reduceRight, flat, flatMap, includes, indexOf, lastIndexOf, find,
    findIndex, findLast, findLastIndex, some, every, sort, toSorted, reverse, toReversed, join, concat,
    at, toString, valueOf, toUpperCase, toLowerCase, trim, trimStart, trimEnd, startsWith, endsWith,
    split, replace, replaceAll, match, matchAll, padStart, padEnd, repeat, charAt, toFixed, toPrecision,
    Map, Set, set, get, has, delete, clear, keys, values, entries, Promise, then, finally, call, apply,
    bind, RegExp, test, exec, URL, URLSearchParams, alert, prompt, confirm%
  },
  keywordstyle=[3]\color{commonfuncs}\bfseries,
  identifierstyle=\color{codefg},
  sensitive=true,
  comment=[l]{//},
  morecomment=[s]{/*}{*/},
  commentstyle=\color{commentcolor}\itshape,
  stringstyle=\color{stringcolor},
  morestring=[b]',
  morestring=[b]"
}

% JavaScript style
\lstdefinestyle{js}{
  backgroundcolor=\color{codebg},
  basicstyle=\ttfamily\small\color{codefg},
  keywordstyle=\color{keywordcolor}\bfseries,
  keywordstyle=[2]\color{functionscolor}\bfseries,
  keywordstyle=[3]\color{commonfuncs}\bfseries,
  stringstyle=\color{stringcolor},
  commentstyle=\color{commentcolor}\itshape,
  numberstyle=\tiny\color{gray},
  numbers=left,
  numbersep=10pt,
  columns=fullflexible,
  keepspaces=true,
  showstringspaces=false,
  breaklines=true,
  frame=single,
  language=JavaScript,
  literate=*%
    % existing operators / punctuation
    {=>}{{{\color{operatorcolor}{=>}}}}2%
    {==}{{{\color{operatorcolor}{===}}}}3%
    {!==}{{{\color{operatorcolor}{!==}}}}3%
    {===}{{{\color{operatorcolor}{==}}}}2%
    {!=}{{{\color{operatorcolor}{!=}}}}2%
    {&&}{{{\color{operatorcolor}{\&\&}}}}2%
    {||}{{{\color{operatorcolor}{||}}}}2%
    {.}{{{\color{gray}{.}}}}1%
    {(}{{{\color{gray}{(}}}}1%
    {)}{{{\color{gray}{)}}}}1%
    {[}{{{\color{gray}{[}}}}1%
    {]}{{{\color{gray}{]}}}}1%
    {\{}{{{\color{gray}{\{}}}}1%
    {\}}{{{\color{gray}{\}}}}}1%
    {,}{{{\color{gray}{,}}}}1%
    {;}{{{\color{gray}{;}}}}1%
}

\lstdefinelanguage{grid-file}{
  keywords={r},
  keywordstyle=\color{grid-road}\bfseries,
  ndkeywords={o},
  ndkeywordstyle=\color{grid-object}\bfseries,
  morekeywords=[2]{n,k},
  keywordstyle=[2]\color{grid-ev}\bfseries,
  morekeywords=[3]{h},
  keywordstyle=[3]\color{grid-handicap}\bfseries,
  morekeywords=[4]{s,m,l},
  keywordstyle=[4]\color{grid-bay}\bfseries,
  sensitive=true,
  morecomment=[l]{\%},
  commentstyle=\color{commentcolor}\itshape
}

% Define mtest C framework language with highlighted functions and macros
\lstdefinelanguage{mtest-C}{
  keywords={void, int, char, float, double, return, if, else, for, while, do, switch, case, break, struct, typedef, unsigned, signed, const, static, extern},
  keywordstyle=\color{C-keywordcolor}\bfseries,
  % Test Case Definition - Vibrant Purple
  ndkeywords={TEST_CASE, MAIN_RUN_TESTS},
  ndkeywordstyle=\color{mtestapi-primary}\bfseries,
  % Core assertion and check macros - Vibrant Teal/Turquoise
  morekeywords=[2]{CHECK, CHECK_, REQUIRE, REQUIRE_, MESSAGE, MESSAGE_, CHECK_FAIL, REQUIRE_FAIL, CHECK_TRUE, CHECK_FALSE, REQUIRE_TRUE, REQUIRE_FALSE},
  keywordstyle=[2]\color{mtestapi-secondary}\bfseries,
  % Integer comparison macros - Vibrant Lime Green
  morekeywords=[3]{CHECK_EQ_INT, CHECK_NE_INT, CHECK_LT_INT, CHECK_GT_INT, CHECK_LE_INT, CHECK_GE_INT, REQUIRE_EQ_INT, REQUIRE_NE_INT, REQUIRE_LT_INT, REQUIRE_GT_INT, REQUIRE_LE_INT, REQUIRE_GE_INT, TRUE, FALSE},
  keywordstyle=[3]\color{mtestapi-tertiary}\bfseries,
  % Double/Float comparison macros - Vibrant Gold/Yellow
  morekeywords=[4]{CHECK_EQ_DOUBLE, CHECK_NE_DOUBLE, CHECK_LT_DOUBLE, CHECK_GT_DOUBLE, CHECK_LE_DOUBLE, CHECK_GE_DOUBLE, REQUIRE_EQ_DOUBLE, REQUIRE_NE_DOUBLE, REQUIRE_LT_DOUBLE, REQUIRE_GT_DOUBLE, REQUIRE_LE_DOUBLE, REQUIRE_GE_DOUBLE},
  keywordstyle=[4]\color{mtestapi-quaternary}\bfseries,
  % Character and String comparison macros - Vibrant Coral/Red
  morekeywords=[5]{CHECK_EQ_CHAR, CHECK_NE_CHAR, REQUIRE_EQ_CHAR, REQUIRE_NE_CHAR, CHECK_EQ_STRING, CHECK_NE_STRING, REQUIRE_EQ_STRING, REQUIRE_NE_STRING},
  keywordstyle=[5]\color{mtestapi-quinary}\bfseries,
  % Utility macros - Vibrant Orange
  morekeywords=[6]{RUN_TESTS},
  keywordstyle=[6]\color{mtestapi-senary}\bfseries,
  morecomment=[l]{//},
  morecomment=[s]{/*}{*/},
  commentstyle=\color{C-commentcolor}\itshape,
  stringstyle=\color{C-stringcolor},
  sensitive=true,
  identifierstyle=\color{C-codefg}
}

